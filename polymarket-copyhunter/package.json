{
  "name": "copyhunter",
  "version": "0.1.0",
  "description": "Smart money copy trading terminal for prediction markets",
  "type": "module",
  "bin": {
    "copyhunter": "./dist/bin/copyhunter.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch bin/copyhunter.ts",
    "start": "tsx bin/copyhunter.ts",
    "test": "tsx --test tests/**/*.test.ts",
    "test:db": "tsx --test tests/db/*.test.ts",
    "test:follow": "tsx --test tests/follow/*.test.ts",
    "test:watch": "tsx --test tests/watch/*.test.ts",
    "test:core": "tsx --test tests/core/*.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "ink": "^5.1.0",
    "@inkjs/ui": "^2.0.0",
    "react": "^18.2.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "ora": "^8.0.0",
    "conf": "^12.0.0",
    "zod": "^3.22.0",
    "better-sqlite3": "^11.5.0",
    "drizzle-orm": "^0.36.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/better-sqlite3": "^7.6.8",
    "vitest": "^1.2.0",
    "drizzle-kit": "^0.28.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "polymarket",
    "copy-trading",
    "prediction-markets",
    "smart-money",
    "cli"
  ],
  "license": "MIT"
}
